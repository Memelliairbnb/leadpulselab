{
  "name": "@alh/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./src/schema": "./dist/schema/index.js",
    "./src/schema/*": "./dist/schema/*.js",
    "./src/repositories/*": "./dist/repositories/*.js",
    "./src/*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.0",
    "@alh/types": "workspace:*"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
