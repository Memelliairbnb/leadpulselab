# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/ai_lead_hunter

# Redis
REDIS_URL=redis://localhost:6379

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048
CLAUDE_TEMPERATURE=0.3

# API
PORT=3001
NODE_ENV=development
INTERNAL_API_TOKEN=your-secure-internal-token
JWT_SECRET=your-jwt-secret
CORS_ORIGIN=http://localhost:3000

# Vercel Dashboard
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret
INTERNAL_API_URL=http://localhost:3001

# Source Adapters
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-lead-hunter/1.0

# Scoring Thresholds
LEAD_SCORE_HOT_THRESHOLD=85
LEAD_SCORE_STRONG_THRESHOLD=70
LEAD_SCORE_NURTURE_THRESHOLD=50
OUTREACH_MIN_SCORE=70
STALE_LEAD_DAYS=30
MAX_OUTREACH_DRAFTS_PER_LEAD=3

# Feature Flags
ENABLE_GOOGLE_SOURCE=true
ENABLE_REDDIT_SOURCE=true
ENABLE_INSTAGRAM_SOURCE=false
ENABLE_LINKEDIN_SOURCE=false

# Observability
LOG_LEVEL=info
SERVICE_NAME=ai-lead-hunter
